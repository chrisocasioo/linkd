{
  "expo": {
    "name": "Linkd",
    "slug": "linkd",
    "owner": "chrisocasio.pr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "linkd",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.santrico.linkd",
      "minimumOsVersion": "15.0",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Linkd uses your camera to scan QR codes.",
        "NSPhotoLibraryAddUsageDescription": "Linkd saves generated QR codes to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.santrico.linkd",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Linkd uses your camera to scan QR codes."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Linkd saves generated QR codes to your photo library.",
          "savePhotosPermission": "Linkd saves generated QR codes to your photo library."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "87c8d6f5-b81d-462c-9127-fb801b45f501"
      },
      "router": {
        "origin": false
      }
    }
  }
}
