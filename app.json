{
  "expo": {
    "name": "Linkd",
    "slug": "linkd",
    "owner": "santrico.support",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "linkd",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.santrico.linkd",
      "appleTeamId": "GQ725BQR6F",
      "minimumOsVersion": "16.4",
      "buildNumber": "84",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.pass-type-identifiers": [
          "GQ725BQR6F.pass.com.santrico.linkd"
        ],
        "com.apple.security.application-groups": [
          "group.com.santrico.linkd"
        ]
      },
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Linkd needs access to your photos to set your profile picture.",
        "NSPhotoLibraryAddUsageDescription": "Linkd saves content to your photo library.",
        "NSContactsUsageDescription": "Linkd adds card details to your address book.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "This app does not use your location.",
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "package": "com.santrico.linkd",
      "versionCode": 1,
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Linkd needs access to your photos to set your profile picture.",
          "cameraPermission": "Linkd needs camera access to scan business cards."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Linkd adds card details to your address book."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Linkd saves content to your photo library.",
          "savePhotosPermission": "Linkd saves content to your photo library."
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-sqlite",
      "@bacons/apple-targets"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.santrico.linkd.widget",
                  "targetName": "LinkdWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.santrico.linkd"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "ae569325-a0ce-4e06-84cf-73ae1caa4c0b"
      }
    }
  }
}
